<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/black"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/back_button"
                android:padding="10dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/avtohit_text" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/projectTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/project_title_default"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/projectSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/project_subtitle_default"
                    android:textColor="#A7A7A7"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="@string/open_settings"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="@color/icon_button_tint" />

                <Button
                    android:id="@+id/exportButton"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_export_button"
                    android:enabled="false"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/export_button"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/selectAudioButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_selectable_action_button"
                android:text="@string/select_mp3"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/selectVisualButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_selectable_action_button"
                android:text="@string/select_visual"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/projectSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_surface_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/projectMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/project_mode_default"
                android:textColor="@color/avtohit_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/visualChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_primary"
                    android:padding="10dp"
                    android:text="@string/visual_not_selected"
                    android:textColor="@color/avtohit_primary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/audioChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_accent"
                    android:padding="10dp"
                    android:text="@string/mp3_not_selected"
                    android:textColor="@color/avtohit_accent"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/exportChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_neutral"
                    android:padding="10dp"
                    android:text="@string/export_resolution_1080"
                    android:textColor="@color/avtohit_text"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/timelineCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_surface_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/timelineTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timeline_title"
                android:textColor="@color/avtohit_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/timelineHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/timeline_hint"
                android:textColor="@color/avtohit_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/timelineCanvas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                    <TextView
                        android:id="@+id/trackVisualLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/track_visual"
                        android:textColor="@color/avtohit_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:id="@+id/visualTrackLane"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_timeline_lane"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/visualTrackClip"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_track_visual"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/visual_track_default"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/visualTrackMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/no_visual_preview"
                        android:textColor="@color/avtohit_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/trackVoiceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/track_voice"
                        android:textColor="@color/avtohit_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:id="@+id/audioTrackLane"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_timeline_lane"
                        android:padding="8dp">

                        <LinearLayout
                            android:id="@+id/audioWaveform"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_track_audio"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />

                        <TextView
                            android:id="@+id/audioTrackClip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="14dp"
                            android:text="@string/audio_track_default"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/audioTrackMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/no_audio_preview"
                        android:textColor="@color/avtohit_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/trackMusicLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/track_music"
                        android:textColor="@color/avtohit_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/musicTrackPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_track_placeholder"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/music_track_empty"
                        android:textColor="@color/avtohit_muted"
                        android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_surface_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/previewTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_title"
                android:textColor="@color/avtohit_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="236dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_preview_backdrop">

                <ImageView
                    android:id="@+id/previewArtwork"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:alpha="0.96"
                    android:contentDescription="@string/preview_title"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_foreground" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_preview_overlay" />

                <TextView
                    android:id="@+id/previewEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="@string/no_visual_preview"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/playButton"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_play_button"
                    android:contentDescription="@string/play_button"
                    android:enabled="false"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="@android:color/white" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/previewModeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_dark"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp"
                        android:text="@string/preview_audio_only"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/previewSeek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:enabled="false"
                        android:max="1000"
                        android:progress="0"
                        android:thumbTint="@android:color/white"
                        android:progressTint="@android:color/white" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/previewTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ready"
                            android:textColor="@android:color/white"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ready"
                            android:textColor="@android:color/white"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:indeterminate="true"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
