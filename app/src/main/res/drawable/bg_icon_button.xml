<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/avtohit_disabled_tint" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/avtohit_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/avtohit_surface" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/avtohit_border" />
        </shape>
    </item>
</selector>
